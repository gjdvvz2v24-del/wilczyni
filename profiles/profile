setpw () {
    if [[ $# -ne 1 ]] ; then
        echo "setpw string"    
    else
        read -s passwd
        security delete-generic-password -a $(whoami) -s $1
        security add-generic-password -a $(whoami) -s $1 -w ${passwd}
    fi
}

getpw () {
    if [[ $# -ne 1 ]] ; then
        echo "gettpw string"
    else
        security find-generic-password -a $(whoami) -s $1 -w
    fi
}

dlink() {
    SRC=$(readlink $1)
    unlink $1
    cp ${SRC} $1
}


profile() {
    FILE=${PROFILE_DIR}/profile
    if [[ ${#} -gt 1  &&  "$1" != "-e" ]] ; then
        FILE=${PROFILE_DIR}/profile.$1
        vim $FILE
    fi

    if [[ "$#" -gt "0" ]] ; then
        if [[ "$1" == "-e" ]] ; then
            vim ${FILE}
        fi
    fi

    source ${FILE}
}

profile-v() {
    if [[  "$#" -ge "1" && "$1" != "-e" ]] ; then
        FILE=${PROFILE_VAULT_DIR}/profile.$1 
    else
        FILE=${PROFILE_VAULT_DIR}/profile.$2
    fi
    if [[ "$#" -gt "0" ]] ; then
        if [[ "$1" == "-e" ]] ; then
            vim ${FILE}
        fi
    else
        ls -1 ${PROFILE_VAULT_DIR}/* | awk '-F.' '{print $NF}'
    fi

    [[ -n ${FILE} ]] && source ${FILE}
}

n() {
    if [[ "$#" == 0 ]] ; then
        ls -1 ~/.notes* | gsed -ne 's/.*.notes_\(.*\)/\1/p' | yank -l
    else
        POSTFIX=$1
        shift
        if [[ "$1" == "-e" ]] ; then
            vim ~/.notes_${POSTFIX}
        elif [[ "$1" == "-l" ]] ; then
            cat ~/.notes_${POSTFIX} | yank -l
        elif [[ "$1" == "-lr" ]] ; then
            while true; do
              cat ~/.notes_${POSTFIX} | yank -l
              pbpaste | bash
            done
        elif [[ "$1" == "-r" ]] ; then
            source ~/.notes_${POSTFIX}
        else
            cat ~/.notes_${POSTFIX}
        fi
   fi
}

fnd() {
    if [[ $# -eq 2 ]] ; then
        find . -iname "*\.$2" -exec grep -iH --color "$1" {} \;
    else
        grep --color -i "$1" * -r --exclude=\*.{svg,py,pyc,plan,backup,tfstate,swp,js,json,html,htm,map,bk,tar,gz,deb,tgz,tf-} --exclude-dir '\.terraform' 2>/dev/null
    fi
}

kms_encrypt() {
    aws kms encrypt --key-id $1 --plaintext $2 --query CiphertextBlob --output text
}

kms_decrypt() {
    aws kms decrypt --ciphertext-blob fileb://<( echo $1 | base64 -D ) --output text --query Plaintext | base64 -D
}


re_tag () {
    if [[ $# == 1 ]] ;then
        echo 'tag message'
        read m
        git tag -d "$1"
        git push --delete origin "$1"
        git tag -a "$1" -m "$m"
        git push --tags
    fi
}

re_branch () {
    BRANCH=$(git branch --show-current)
    git checkout master
    git pull
    git branch -D ${BRANCH}
    git checkout -b ${BRANCH}
}

tfmask() {
    for i in $@ ; do
        mv "$i" "_$i-"
    done
}

tfunmask() {
    for i in $@ ; do
        mv  -- "$i" "$(echo $i|sed -e 's/^_//g' -e 's/-$//g')"
    done
}

git-url() {
    REPO=`git rev-parse --show-toplevel`

    if [[ $? -ne 0 ]]
    then
        echo "Not in git repo"
        exit 1
    fi

    git_branch=`git rev-parse --abbrev-ref HEAD 2>/dev/null`
    relative_path=`git rev-parse --show-prefix|gsed "s/\/$//"`
    GIT_REMOTE_URL_UNFINISHED=`git config --get remote.origin.url|gsed -s "s/^ssh/http/; s/git@//; s/.git$//; s/:/\//g"`
    GIT_REMOTE_URL="$(dirname $GIT_REMOTE_URL_UNFINISHED)/$(basename $GIT_REMOTE_URL_UNFINISHED)/tree/$relative_path"
    git_branch_in_url=`echo $git_branch| gsed 's/\//%2F/g'`
    GIT_REMOTE_URL="$(dirname $GIT_REMOTE_URL_UNFINISHED)/$(basename $GIT_REMOTE_URL_UNFINISHED)/tree/$git_branch_in_url/$relative_path"
    echo $GIT_REMOTE_URL
}

