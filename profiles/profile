}

aws-login () {
    if [ $# -gt 1 ]; then
        x=-s
    fi
    aws-vault login $1 -t $(oathtool -b --totp $(getpw aws_mfa)) $x
}

vv () {
    profile=$1
    shift 1
    aws-vault exec $profile -t $(oathtool -b --totp $(getpw aws_mfa)) -- $@
}

